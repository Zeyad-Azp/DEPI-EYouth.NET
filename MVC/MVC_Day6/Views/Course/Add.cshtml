@using MVC_Day6.ViewModels
@using MVC_Day6.ViewModels.Course
@model AddCourseViewModel

@{
    ViewData["Title"] = "Add Course";
}

<div class="container mt-5">
    <div class="card shadow-lg p-5">
        <h2 class="text-center text-success mb-4">➕ Add New Course</h2>

        <form asp-controller="Course" asp-action="SaveAdd" method="post">

            <!-- Name -->
            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-bold"></label>
                <input asp-for="Name" class="form-control" placeholder="Enter course name" />
                <span asp-validation-for="Name" class="text-danger"></span>
            </div>

            <!-- Degree -->
            <div class="mb-3">
                <label asp-for="Degree" class="form-label fw-bold"></label>
                <input asp-for="Degree" class="form-control" placeholder="Enter degree" />
                <span asp-validation-for="Degree" class="text-danger"></span>
            </div>

            <!-- Min Degree -->
            <div class="mb-3">
                <label asp-for="MinDegree" class="form-label fw-bold"></label>
                <input asp-for="MinDegree" class="form-control" placeholder="Enter minimum degree" />
                <span asp-validation-for="MinDegree" class="text-danger"></span>
            </div>

            <!-- Department -->
            <div class="mb-4">
                <label asp-for="DepartmentId" class="form-label fw-bold"></label>
                <select asp-for="DepartmentId" asp-items="ViewBag.depts" class="form-select">
                    <option value="0">-- Select Department --</option>
                </select>
                <span asp-validation-for="DepartmentId" class="text-danger"></span>
            </div>

            <!-- Buttons -->
            <div class="d-flex justify-content-between">
                <a asp-controller="Course" asp-action="Index" class="btn btn-secondary">
                    ⬅ Cancel
                </a>

                <button type="submit" class="btn btn-success px-4">
                    💾 Save
                </button>
            </div>

        </form>
    </div>
</div>

