@model List<Course>

@{
    ViewData["Title"] = "Courses";
}

<div class="container mt-5">
    <h2 class="text-center mb-4 text-primary">📚 Courses List</h2>
    
    <a asp-controller="Course"
       asp-action="Add"
       class="btn btn-success shadow-sm px-4">
        ➕ Add Course
    </a>

    <div class="card shadow-lg p-4">
        <table class="table table-hover table-bordered text-center align-middle">
            <thead class="table-dark">
                <tr>
                    <th>ID</th>
                    <th>Name</th>
                    <th>Degree</th>
                    <th>Min Degree</th>
                    <th>Department</th>
                    <th>Details</th>
                    <th>Update</th>
                    <th>Delete</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var course in Model)
                {
                    <tr>
                        <td>@course.Id</td>
                        <td class="fw-bold text-success">@course.Name</td>
                        <td>
                            <span class="badge bg-info text-dark">
                                @course.Degree
                            </span>
                        </td>
                        <td>
                            <span class="badge bg-warning text-dark">
                                @course.MinDegree
                            </span>
                        </td>
                        <td>@course.Dept?.Name</td>
                        <td>
                            <a asp-controller="Course" asp-action="GetById"
                               asp-route-id="@course.Id"
                               class="btn btn-outline-primary btn-sm">
                                View
                            </a>
                        </td>
                        <td>
                            <a asp-controller="Course" asp-action="Update"
                               asp-route-id="@course.Id"
                               class="btn btn-outline-primary btn-sm">
                                Update
                            </a>
                        </td>
                        <td>
                            <a asp-controller="Course" asp-action="Delete"
                               asp-route-id="@course.Id"
                               class="btn btn-outline-primary btn-sm">
                                Delete
                            </a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>