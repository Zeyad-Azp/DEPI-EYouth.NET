@using Application.ViewModels.TaskItem
@model UpdateTaskItemViewModel

<h2>Update Task</h2>

<form asp-controller="TaskItem" asp-action="Update" asp-route-id="@Model.Id" method="post">
    <div class="mb-3">
        <label>Title</label>
        <input asp-for="Title" class="form-control" />
        <span asp-validation-for="Title"></span>
    </div>

    <div class="mb-3">
        <label>Description</label>
        <input asp-for="Description" class="form-control" />
        <span asp-validation-for="Description"></span>
    </div>
    <div class="mb-3">
        <label>Due Date</label>
        <input asp-for="DueDate" type="date" class="form-control" />
        <span asp-validation-for="DueDate" class="text-danger"></span>
    </div>
    <div class="form-check">
        <input asp-for="IsCompleted" class="form-check-input" />
        <label class="form-check-label">Completed</label>
    </div>
    <button type="submit" class="btn btn-success">Update</button>
    <a asp-controller="TaskItem" asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>