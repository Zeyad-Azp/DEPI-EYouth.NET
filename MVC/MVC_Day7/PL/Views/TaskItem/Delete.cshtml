@using Application.ViewModels.TaskItem
@model DeleteTaskItemViewModel

<h2 class="text-danger">Delete Task</h2>

<h4>Are you sure you want to delete this task?</h4>

<div class="card p-3 mt-3">

    <div class="mb-2">
        <strong>Title:</strong>
        <p>@Model.Title</p>
    </div>

    <div class="mb-2">
        <strong>Description:</strong>
        <p>@Model.Description</p>
    </div>

    <div class="mb-2">
        <strong>Status:</strong>
        <span class=@Model.StyleClass>@Model.Status</span>
    </div>

    <div class="mb-2">
        <strong>Created At:</strong>
        <p>@Model.CreatedAt.ToString("yyyy-MM-dd")</p>
    </div>

    <div class="mb-2">
        <strong>Due Date:</strong>
        <p>
            @(Model.DueDate.HasValue 
                ? Model.DueDate.Value.ToString("yyyy-MM-dd") 
                : "No Due Date")
        </p>
    </div>

</div>

<br />

<form asp-controller="TaskItem" asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />

    <button type="submit" class="btn btn-danger">
        Yes, Delete
    </button>

    <a asp-controller="TaskItem" asp-action="Index" class="btn btn-secondary">
        Cancel
    </a>
</form>