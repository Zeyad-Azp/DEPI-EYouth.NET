@using Application.ViewModels.TaskItem
@model IEnumerable<GetAllTaskItemViewModel>

<h2>Task List</h2>

<a asp-action="Add" method="post" class="btn btn-primary mb-3">Add New Task</a>

<table class="table table-bordered">
    <thead>
        <tr>
            <th>Title</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var item in Model)
        {
            <tr>
                <td>@item.Title</td>
                <td>
                    <a asp-action="GetById" asp-route-id="@item.Id" class="btn btn-warning">View Details</a>
                    <a asp-action="Update" asp-route-id="@item.Id" class="btn btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@item.Id" class="btn btn-warning" method="post" style="display:inline;">Delete</a>
                </td>
            </tr>
        }
        <a asp-action="Filter" asp-controller="TaskItem" class="btn btn-warning">Filter By Is Completed</a>
        <a asp-action="Sort" asp-controller="TaskItem" class="btn btn-warning">Sort By Due Date</a>
    </tbody>
</table>