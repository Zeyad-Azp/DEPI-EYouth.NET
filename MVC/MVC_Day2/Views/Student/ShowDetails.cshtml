@model Student

<h2>Student Details</h2>

<table class="table table-bordered">
    <tr>
        <th>Id</th>
        <td>@Model.Id</td>
    </tr>

    <tr>
        <th>Name</th>
        <td>@Model.Name</td>
    </tr>

    <tr>
        <th>Age</th>
        <td>@Model.Age</td>
    </tr>

    <tr>
        <th>Department</th>
        <td>@Model.dept?.Name ?? "None"</td>
    </tr>
</table>
