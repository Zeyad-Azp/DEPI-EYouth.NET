@using MVC_Day4.ViewModels.Department
@model DepartmentViewModel
<h2>Department Details</h2>

<div>
    <h4>Department Name: @Model.Name</h4>
</div>
<div>
    <h5>Department State: @Model?.State</h5>
</div>

<div class="form-group">
    <label>Select Student (Age > 25)</label>

    <select asp-items="@Model?.Students"></select>
</div>