# ################################################################################
# Visual Studio / ASP.NET Core .gitignore (Clean Version)
# ################################################################################

# Build folders
bin/
obj/

# Visual Studio files
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Logs
*.log

# OS files
.DS_Store
Thumbs.db

# Environment files (VERY IMPORTANT)
appsettings.Development.json
appsettings.Local.json

# Secrets (never push these)
secrets.json

# Publish output
publish/

# Node modules (if frontend inside project)
node_modules/

# EF Core temp / design files
*.dbmdl

# Coverage reports
coverage/
*.coverage
*.coveragexml

# Temporary files
*.tmp
*.temp

# SQLite DB (optional)
*.db
*.sqlite

# Package managers
packages/

# Resharper
_ReSharper*/
*.DotSettings.user
